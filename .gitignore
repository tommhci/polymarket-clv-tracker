# Environment & secrets (NEVER commit)
.env
*.env

# SQLite databases — NOT tracked in git (binary, causes repo bloat antipattern)
# Source: StackOverflow/openillumi.com — binary DB in git = unreadable diffs + bloat
# The docs/scans.csv + docs/paper_trades.csv are the portable truth source instead
*.db

