# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: The Odds API ────────────────────────────────────────────────────
# Free tier: 500 requests/month. Sign up at https://the-odds-api.com
# One call per scan fetches ALL WC events — 500 calls covers months of scanning
ODDS_API_KEY=your_odds_api_key_here

# ── Optional: Telegram alerts ─────────────────────────────────────────────────
# Without these, alerts print to stdout only (still works for local testing)
#
# Step 1: Message @BotFather on Telegram → /newbot → copy the token
# Step 2: Start a chat with your bot, then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
#   Copy the "id" field from "chat" object — that's your CHAT_ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── GLM (智谱AI) — Optional AI-powered market parsing ────────────────────────
# Get your key at: https://open.bigmodel.cn → 控制台 → API Keys
# Without this, scanner uses keyword matching (still works, just less precise)
GLM_API_KEY=your_glm_api_key_here
# GLM_MODEL=glm-4-flash          # cheapest; glm-4 or glm-4-plus for higher accuracy
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4  # default China endpoint

# ── Optional overrides ────────────────────────────────────────────────────────
# ODDS_SPORT_KEY=soccer_fifa_world_cup   # change if Odds API key changes
# DB_PATH=polymarket_tracker.db          # SQLite file path
